#!/usr/bin/env bash

# gconf — manage per-user git identity for the current repository
#
# Usage:
#   gconf apply|a  <username>
#   gconf create|c <username> [email] [ssh_key] [gpg_key]
#   (email defaults to username@users.noreply.github.com)
#
# Conventions:
#   ssh key:     ~/.ssh/id_<username>      (default)
#   config file: ~/.gitconfig.<username>   (auto-included on apply)

function gconf() {
  local cmd="${1:-}"
  shift 2>/dev/null

  case "$cmd" in
    apply|a)  _gconf_apply "$@" ;;
    create|c) _gconf_create "$@" ;;
    *)
      echo "Usage:"
      echo "  gconf apply|a  <username>"
      echo "  gconf create|c <username> [email] [ssh_key] [gpg_key]"
      return 1
      ;;
  esac
}

function _gconf_apply() {
  if [ $# -lt 1 ]; then
    echo "Usage: gconf apply <username>"
    return 1
  fi

  local username="$1"
  local user_config_file="$HOME/.gitconfig.$username"

  if [ ! -f "$user_config_file" ]; then
    echo "Config not found: $user_config_file"
    echo "Create it first: gconf create $username [email]"
    return 1
  fi

  git config include.path "$user_config_file"

  printf "\nGit local config set:\n"
  git config --local --list | grep -v '^branch\.'
}

function _gconf_create() {
  if [ $# -lt 1 ]; then
    echo "Usage: gconf create <username> [email] [ssh_key] [gpg_key]"
    return 1
  fi

  local username="$1"
  local user_email="${2:-$username@users.noreply.github.com}"
  local ssh_key_path="${3:-$HOME/.ssh/github_${username}}"
  local gpg_key="$4"
  local config_file="$HOME/.gitconfig.$username"

  if [ -f "$config_file" ]; then
    echo "Config already exists: $config_file"
    echo "Remove it first if you want to recreate."
    return 1
  fi

  cat > "$config_file" <<EOF
[user]
	name = $username
	email = $user_email

[core]
	sshCommand = ssh -i $ssh_key_path -o IdentitiesOnly=yes
EOF

  if [ -n "$gpg_key" ]; then
    cat >> "$config_file" <<EOF

[user]
	signingkey = $gpg_key

[commit]
	gpgsign = true

[gpg]
	program = gpg
EOF
  fi

  if [ ! -f "$ssh_key_path" ]; then
    echo "Note: SSH key not found at $ssh_key_path"
  fi

  echo "Created $config_file"
  cat "$config_file"
}
